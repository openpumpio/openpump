{
  "name": "@openpump/solana-agent-kit",
  "version": "0.1.1",
  "private": false,
  "type": "module",
  "license": "MIT",
  "description": "OpenPump plugin for Solana Agent Kit v2 - PumpFun token trading for AI agents",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/openpumpio/openpump.git",
    "directory": "packages/solana-agent-kit"
  },
  "keywords": [
    "solana",
    "agent-kit",
    "pumpfun",
    "ai-agent",
    "openpump",
    "mcp"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run"
  },
  "peerDependencies": {
    "solana-agent-kit": "^2.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@openpump/typescript-config": "workspace:*",
    "solana-agent-kit": "^2.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^2.0.0",
    "zod": "^3.22.0"
  }
}
